  "extra": [
    { "text": "وَقَالَ رَبُّكُمُ ادْعُونِي أَسْتَجِبْ لَكُمْ", "source": "غافر ٦٠" },
    { "text": "حَسْبُنَا اللَّهُ وَنِعْمَ الْوَكِيلُ", "source": "آل عمران ١٧٣" },
    { "text": "وَهُوَ مَعَكُمْ أَيْنَ مَا كُنتُمْ", "source": "الحديد ٤" },
    { "text": "إِنَّ اللَّهَ مَعَ الصَّابِرِينَ", "source": "البقرة ١٥٣" },
    { "text": "وَنُنَزِّلُ مِنَ الْقُرْآنِ مَا هُوَ شِفَاءٌ وَرَحْمَةٌ لِّلْمُؤْمِنِينَ", "source": "الإسراء ٨٢" },
    { "text": "يَا أَيُّهَا الَّذِينَ آمَنُوا اذْكُرُوا اللَّهَ ذِكْرًا كَثِيرًا", "source": "الأحزاب ٤١" },
    { "text": "وَاللَّهُ يُحِبُّ الْمُحْسِنِينَ", "source": "آل عمران ١٣٤" },
    { "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ", "source": "البقرة ٢٠١" },
    { "text": "رَبِّ اشْرَحْ لِي صَدْرِي وَيَسِّرْ لِي أَمْرِي", "source": "طه ٢٥-٢٦" },
    { "text": "رَبِّ زِدْنِي عِلْمًا", "source": "طه ١١٤" },
    { "text": "لَا إِلَهَ إِلَّا أَنتَ سُبْحَانَكَ إِنِّي كُنتُ مِنَ الظَّالِمِينَ", "source": "الأنبياء ٨٧" },
    { "text": "رَبَّنَا لَا تُؤَاخِذْنَا إِن نَّسِينَا أَوْ أَخْطَأْنَا", "source": "البقرة ٢٨٦" },
    { "text": "اللَّهُمَّ أَعِنِّي عَلَى ذِكْرِكَ وَشُكْرِكَ وَحُسْنِ عِبَادَتِكَ", "source": "رواه أبو داود" },
    { "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْهُدَى وَالتُّقَى وَالْعَفَافَ وَالْغِنَى", "source": "رواه مسلم" },
    { "text": "اللَّهُمَّ إِنَّكَ عَفُوٌّ كَرِيمٌ تُحِبُّ الْعَفْوَ فَاعْفُ عَنِّي", "source": "رواه الترمذي" },
    { "text": "اللَّهُمَّ بَارِكْ لَنَا فِيمَا رَزَقْتَنَا وَقِنَا عَذَابَ النَّارِ", "source": "دعاء مأثور" },

    { "text": "وَإِذَا سَأَلَكَ عِبَادِي عَنِّي فَإِنِّي قَرِيبٌ أُجِيبُ دَعْوَةَ الدَّاعِ إِذَا دَعَانِ", "source": "البقرة ١٨٦" },
    { "text": "وَاسْتَعِينُوا بِالصَّبْرِ وَالصَّلَاةِ", "source": "البقرة ٤٥" },
    { "text": "إِنَّ اللَّهَ يَأْمُرُ بِالْعَدْلِ وَالْإِحْسَانِ وَإِيتَاءِ ذِي الْقُرْبَىٰ", "source": "النحل ٩٠" },
    { "text": "وَتَعَاوَنُوا عَلَى الْبِرِّ وَالتَّقْوَىٰ", "source": "المائدة ٢" },
    { "text": "إِنَّمَا يُوَفَّى الصَّابِرُونَ أَجْرَهُم بِغَيْرِ حِسَابٍ", "source": "الزمر ١٠" },
    { "text": "فَاسْتَبِقُوا الْخَيْرَاتِ", "source": "البقرة ١٤٨" },
    { "text": "إِنَّ اللَّهَ لَا يُضِيعُ أَجْرَ الْمُحْسِنِينَ", "source": "التوبة ١٢٠" },
    { "text": "وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُ", "source": "الزلزلة ٧" },

    { "text": "الدِّينُ النَّصِيحَةُ", "source": "رواه مسلم" },
    { "text": "المُسْلِمُ مَنْ سَلِمَ المُسْلِمُونَ مِنْ لِسَانِهِ وَيَدِهِ", "source": "متفق عليه" },
    { "text": "مَنْ كَانَ يُؤْمِنُ بِاللَّهِ وَاليَوْمِ الآخِرِ فَلْيَقُلْ خَيْرًا أَوْ لِيَصْمُتْ", "source": "متفق عليه" },
    { "text": "لَا يُؤْمِنُ أَحَدُكُمْ حَتَّى يُحِبَّ لِأَخِيهِ مَا يُحِبُّ لِنَفْسِهِ", "source": "متفق عليه" },
    { "text": "اتَّقِ اللَّهَ حَيْثُمَا كُنْتَ، وَأَتْبِعِ السَّيِّئَةَ الحَسَنَةَ تَمْحُهَا", "source": "رواه الترمذي" },
    { "text": "مَنْ سَلَكَ طَرِيقًا يَلْتَمِسُ فِيهِ عِلْمًا سَهَّلَ اللَّهُ لَهُ بِهِ طَرِيقًا إِلَى الجَنَّةِ", "source": "رواه مسلم" },
