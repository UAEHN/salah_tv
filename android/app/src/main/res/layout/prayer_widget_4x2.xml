<?xml version="1.0" encoding="utf-8"?>
<!-- Prayer widget 4x2: header (city + hijri) → hero (next prayer + countdown)
     → today's 5-prayer strip with active highlighted. Background gradient is
     swapped at runtime via PrayerWidgetProvider based on the current prayer. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_isha"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <!-- Header: city left, hijri right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍"
            android:textColor="#D4A843"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/widget_city"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#B8C2D6"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""/>

        <TextView
            android:id="@+id/widget_hijri"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8A93AD"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""/>
    </LinearLayout>

    <!-- Hero row: next prayer name + countdown -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_next_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#D4A843"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="—"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8A93AD"
                android:textSize="10sp"
                android:text="باقٍ على الأذان"/>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F0F4FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFeatureSettings="tnum"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""/>
    </LinearLayout>

    <!-- 5-prayer strip: each cell = name on top, time below; active gets pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5">

        <LinearLayout
            android:id="@+id/slot_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/widget_pill_inactive">
            <TextView
                android:id="@+id/slot_0_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B8C2D6"
                android:textSize="11sp"
                android:maxLines="1"
                android:text=""/>
            <TextView
                android:id="@+id/slot_0_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F0F4FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:maxLines="1"
                android:text=""/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slot_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/widget_pill_inactive">
            <TextView
                android:id="@+id/slot_1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B8C2D6"
                android:textSize="11sp"
                android:maxLines="1"
                android:text=""/>
            <TextView
                android:id="@+id/slot_1_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F0F4FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:maxLines="1"
                android:text=""/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slot_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/widget_pill_inactive">
            <TextView
                android:id="@+id/slot_2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B8C2D6"
                android:textSize="11sp"
                android:maxLines="1"
                android:text=""/>
            <TextView
                android:id="@+id/slot_2_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F0F4FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:maxLines="1"
                android:text=""/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slot_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/widget_pill_inactive">
            <TextView
                android:id="@+id/slot_3_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B8C2D6"
                android:textSize="11sp"
                android:maxLines="1"
                android:text=""/>
            <TextView
                android:id="@+id/slot_3_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F0F4FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:maxLines="1"
                android:text=""/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slot_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/widget_pill_inactive">
            <TextView
                android:id="@+id/slot_4_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B8C2D6"
                android:textSize="11sp"
                android:maxLines="1"
                android:text=""/>
            <TextView
                android:id="@+id/slot_4_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F0F4FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:maxLines="1"
                android:text=""/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
