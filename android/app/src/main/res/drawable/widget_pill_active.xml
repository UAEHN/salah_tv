<?xml version="1.0" encoding="utf-8"?>
<!-- Gold pill background marking the next prayer in the strip. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#33D4A843"
        android:endColor="#1AD4A843"
        android:type="linear"/>
    <corners android:radius="14dp"/>
    <stroke android:width="1dp" android:color="#66D4A843"/>
</shape>
