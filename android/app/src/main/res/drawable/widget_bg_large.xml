<?xml version="1.0" encoding="utf-8"?>
<!-- Large widget background: matches app's dark theme bgDeep → bgSurface gradient.
     Mirrors lib/core/app_colors.dart kDarkBgDeep / kDarkBgSurface. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#162035"
        android:centerColor="#0C1528"
        android:endColor="#07101E"
        android:type="linear"/>
    <corners android:radius="28dp"/>
    <stroke android:width="1dp" android:color="#2AFFFFFF"/>
</shape>
